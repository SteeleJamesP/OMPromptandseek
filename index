  var titleClass = c.type==='real'?'accent':c.type==='decoy'?'danger':'warning';
  var typeLabel = c.type==='real'?'Real Clue':c.type==='decoy'?'Decoy Clue':'GIF Page';
  var html = '<div class="editor-header"><div><div style="font-size:10px;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-bottom:5px">' + typeLabel + '</div>' +
    '<div class="editor-title">Editing: <span class="' + titleClass + '">' + escHtml(c.name) + '</span></div></div>' +
    '<span class="badge ' + badgeClass + '">' + c.id + '</span></div>' +
    '<div class="field-group"><label class="field-label">Name</label><input class="field-input" type="text" value="' + escHtml(c.name) + '" oninput="updateField(\'name\',this.value)"></div>';
  if(c.type==='real') {
    html += '<div class="field-group"><label class="field-label">Location (internal)</label><input class="field-input" type="text" value="' + escHtml(c.location||'') + '" oninput="updateField(\'location\',this.value)"></div>' +
      '<div class="field-group"><label class="field-label">AI Prompt (shown to player)</label><textarea class="field-input field-textarea" oninput="updateField(\'prompt\',this.value)">' + escHtml(c.prompt||'') + '</textarea></div>' +
      '<div class="field-group"><label class="field-label">Admin Hint</label><input class="field-input" type="text" value="' + escHtml(c.hint||'') + '" oninput="updateField(\'hint\',this.value)"></div>';
  } else if(c.type==='decoy') {
    html += '<div class="field-group"><label class="field-label">Decoy Type</label><select class="field-input field-select" onchange="updateField(\'subtype\',this.value)">' +
      ['phish','fake-win','loop','wrong'].map(function(s){return '<option value="'+s+'"'+(c.subtype===s?' selected':'')+'>'+s+'</option>';}).join('') +
      '</select></div>' +
      '<div class="field-group"><label class="field-label">Troll Headline</label><input class="field-input" type="text" value="' + escHtml(c.trollMsg||'') + '" oninput="updateField(\'trollMsg\',this.value)"></div>' +
      '<div class="field-group"><label class="field-label">Troll Subtext</label><textarea class="field-input field-textarea" style="min-height:70px" oninput="updateField(\'trollSub\',this.value)">' + escHtml(c.trollSub||'') + '</textarea></div>' +
      '<div class="field-group"><label class="field-label">GIF URL (optional)</label>' +
      '<input class="field-input" type="text" value="' + escHtml(c.gifUrl||'') + '" oninput="updateField(\'gifUrl\',this.value)" placeholder="Paste any Giphy URL — auto-converted">' +
      '<div style="font-size:10px;color:var(--muted);margin-top:5px">Tip: paste any giphy.com URL and it will be fixed automatically.</div></div>' +
      '<div class="field-group"><label class="field-label">Caption (shown under GIF)</label>' +
      '<textarea class="field-input field-textarea" style="min-height:60px" oninput="updateField(\'caption\',this.value)" placeholder="e.g. This is Steve every single Monday morning.">' + escHtml(c.caption||'') + '</textarea></div>';
  } else {
    var previewUrl = fixGifUrl(c.gifUrl);
    html += '<div class="field-group"><label class="field-label">GIF URL</label>' +
      '<input class="field-input" type="text" value="' + escHtml(c.gifUrl||'') + '" oninput="updateField(\'gifUrl\',this.value)" placeholder="Paste any Giphy URL — auto-converted">' +
      '<div style="font-size:10px;color:var(--muted);margin-top:5px">Tip: paste any giphy.com URL and it will be fixed automatically.</div></div>';
    if(previewUrl) html += '<div style="margin-bottom:16px"><img src="' + escHtml(previewUrl) + '" style="max-width:100%;max-height:200px;border-radius:8px;object-fit:contain"></div>';
    html += '<div class="field-group"><label class="field-label">Caption (shown under GIF)</label>' +
      '<textarea class="field-input field-textarea" style="min-height:60px" oninput="updateField(\'caption\',this.value)" placeholder="e.g. This is Karen every Monday. Every. Single. Monday.">' + escHtml(c.caption||'') + '</textarea></div>';
  }
  html += '<div class="divider"></div>' +
    '<div style="margin-bottom:12px"><div class="field-label" style="margin-bottom:6px">QR Code URL</div>' +
    '<div style="background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:9px 13px;font-size:11px;word-break:break-all;color:var(--accent2);font-family:var(--mono)">' + escHtml(url) + '</div></div>' +
    '<div class="action-row"><button class="btn btn-primary" onclick="openQRModal(\'' + c.id + '\')">Generate QR Code</button>' +
    '<button class="btn btn-del" onclick="deleteClue(\'' + c.id + '\')">Delete</button></div>';
  panel.innerHTML = html;
}

function updateField(field, val) {
  var c = getById(selectedId);
  if(c) { c[field] = val; save(); renderSidebar(); }
}

function addClue(type) {
  var id = type[0] + Date.now();
  var base = {id:id, type:type, name:'New ' + (type==='real'?'Clue':type==='decoy'?'Decoy':'GIF Page')};
  if(type==='real') { base.location=''; base.prompt=''; base.hint=''; }
  else if(type==='decoy') { base.subtype='loop'; base.trollMsg='NICE TRY.'; base.trollSub='Get back to it.'; base.gifUrl=''; }
  else { base.gifUrl=''; }
  clues.push(base); save(); selectClue(id); renderSidebar();
}

function deleteClue(id) {
  if(!confirm('Delete this item?')) return;
  clues = clues.filter(function(c){return c.id!==id;});
  selectedId = null; save(); renderSidebar(); renderEditor();
}

// BULK IMPORT
function showBulkImport() { document.getElementById('bulk-modal').classList.add('open'); setTimeout(function(){ document.getElementById('bulk-textarea').focus(); },100); }
function closeBulkModal() { document.getElementById('bulk-modal').classList.remove('open'); }
function doBulkImport() {
  var raw = document.getElementById('bulk-textarea').value.trim();
  var urls = raw.split('\n').map(function(u){return u.trim();}).filter(function(u){return u.length>0;});
  if(!urls.length) { showToast('No URLs found'); return; }
  urls.forEach(function(url, i) {
    clues.push({id:'g'+Date.now()+'_'+i, type:'gif', name:'GIF Page '+(i+1), gifUrl:url});
  });
  save(); renderSidebar(); closeBulkModal();
  showToast('Imported ' + urls.length + ' GIF page' + (urls.length!==1?'s':''));
  document.getElementById('bulk-textarea').value = '';
}

// QR
function openQRModal(id) {
  activeQRId = id;
  var c = getById(id);
  var url = getBaseUrl() + '?id=' + id;
  document.getElementById('qr-modal-sub').textContent = c ? c.name : id;
  document.getElementById('qr-url-display').textContent = url;
  var container = document.getElementById('qr-container');
  container.innerHTML = '';
  try { new QRCode(container, {text:url,width:200,height:200,colorDark:'#000000',colorLight:'#ffffff',correctLevel:QRCode.CorrectLevel.H}); }
  catch(e) { container.innerHTML='<div style="width:200px;height:200px;background:#fff;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:10px;color:#333;padding:16px;text-align:center;word-break:break-all">'+escHtml(url)+'</div>'; }
  document.getElementById('qr-modal').classList.add('open');
}
function closeQRModal() { document.getElementById('qr-modal').classList.remove('open'); }
function downloadQR() {
  var canvas = document.getElementById('qr-container').querySelector('canvas');
  if(!canvas){showToast('No QR found');return;}
  var link = document.createElement('a');
  link.download = 'qr-' + (activeQRId||'item') + '.png';
  link.href = canvas.toDataURL();
  link.click();
}
document.getElementById('qr-modal').addEventListener('click', function(e){if(e.target===this)closeQRModal();});
document.getElementById('bulk-modal').addEventListener('click', function(e){if(e.target===this)closeBulkModal();});

// UTILS
function showToast(msg) {
  var t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(function(){t.classList.remove('show');}, 2500);
}
function escHtml(s) {
  return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// INIT
renderHuntView();
</script>
</body>
