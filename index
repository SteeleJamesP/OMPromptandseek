function fixGifUrl(url) {
  if(!url) return '';
  // Already an embed URL
  if(url.indexOf('giphy.com/embed/') !== -1) return url;
  // Long media URL: extract ID
  var mediaMatch = url.match(/giphy\.com\/media\/(?:v1\.[^/]+\/)?([a-zA-Z0-9]+)\/giphy\.gif/);
  if(mediaMatch) return 'https://giphy.com/embed/' + mediaMatch[1];
  // giphy.com/gifs/some-slug-ID — ID is last hyphen segment
  var gifsMatch = url.match(/giphy\.com\/gifs\/(?:[^/]+-)?([a-zA-Z0-9]+)$/);
  if(gifsMatch) return 'https://giphy.com/embed/' + gifsMatch[1];
  // i.giphy.com/ID.gif
  var iMatch = url.match(/i\.giphy\.com\/([a-zA-Z0-9]+)\.gif/);
  if(iMatch) return 'https://giphy.com/embed/' + iMatch[1];
  // Already a plain ID (no slashes, no dots)
  if(/^[a-zA-Z0-9]+$/.test(url.trim())) return 'https://giphy.com/embed/' + url.trim();
  return url;
}

function renderGifPage(el, c) {
  var embedUrl = fixGifUrl(c.gifUrl);
  var captionHtml = c.caption ? '<div class="gif-caption">' + escHtml(c.caption) + '</div>' : '';
