<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Prompt & Seek — AI Scavenger Hunt</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Syne:wght@400;600;800&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0a0a0f;--surface:#111118;--surface2:#1a1a24;
  --border:rgba(120,120,200,0.15);--border2:rgba(120,120,200,0.3);
  --accent:#7c6af7;--accent2:#3fe8c8;--danger:#f74e6a;--warning:#f7a35c;
  --text:#e8e8f0;--muted:#8888aa;
  --mono:'Space Mono',monospace;--display:'Syne',sans-serif;
  --glow:0 0 24px rgba(124,106,247,0.25);
}
body{background:var(--bg);color:var(--text);font-family:var(--mono);min-height:100vh;overflow-x:hidden}
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(124,106,247,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(124,106,247,0.03) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0}
.app{position:relative;z-index:1}
.hidden{display:none!important}
.header{padding:18px 28px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border);background:rgba(10,10,15,0.9);backdrop-filter:blur(12px);position:sticky;top:0;z-index:100}
.logo{font-family:var(--display);font-size:18px;font-weight:800;display:flex;align-items:center;gap:10px}
.logo-icon{width:30px;height:30px;background:linear-gradient(135deg,var(--accent),var(--accent2));border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:15px}
.logo-sub{font-family:var(--mono);font-size:9px;color:var(--muted);letter-spacing:2px;text-transform:uppercase;display:block}
.header-tabs{display:flex;gap:4px;background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:4px}
.tab{padding:7px 14px;border-radius:7px;border:none;background:transparent;color:var(--muted);font-family:var(--mono);font-size:11px;cursor:pointer;transition:all 0.2s;letter-spacing:0.5px}
.tab.active{background:var(--accent);color:white}
.view{display:none}.view.active{display:block}
.admin-layout{display:grid;grid-template-columns:280px 1fr;min-height:calc(100vh - 61px)}
.sidebar{border-right:1px solid var(--border);padding:20px;background:var(--surface);overflow-y:auto;max-height:calc(100vh - 61px)}
.sidebar-title{font-size:10px;font-weight:600;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-bottom:12px;margin-top:4px}
.clue-list{display:flex;flex-direction:column;gap:6px}
.clue-item{padding:11px 14px;border:1px solid var(--border);border-radius:8px;cursor:pointer;transition:all 0.2s;background:var(--surface2);position:relative;overflow:hidden}
.clue-item::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;opacity:0;transition:opacity 0.2s}
.clue-item.type-real::before{background:var(--accent)}
.clue-item.type-decoy::before{background:var(--danger)}
.clue-item.type-gif::before{background:var(--warning)}
.clue-item:hover{border-color:var(--border2)}
.clue-item.selected{border-color:var(--accent)}
.clue-item.selected.type-decoy{border-color:var(--danger)}
.clue-item.selected.type-gif{border-color:var(--warning)}
.clue-item.selected::before{opacity:1}
.clue-tag{font-size:9px;letter-spacing:2px;text-transform:uppercase;margin-bottom:3px}
.clue-tag.real{color:var(--accent)}.clue-tag.decoy{color:var(--danger)}.clue-tag.gif{color:var(--warning)}
.clue-name{font-family:var(--display);font-size:13px;font-weight:600;color:var(--text)}
.clue-loc{font-size:10px;color:var(--muted);margin-top:2px}
.add-btn{width:100%;margin-top:8px;padding:10px;border:1px dashed var(--border2);border-radius:8px;background:transparent;color:var(--muted);font-family:var(--mono);font-size:11px;cursor:pointer;transition:all 0.2s;letter-spacing:1px}
.add-btn:hover{border-color:var(--accent);color:var(--accent)}
.add-btn.danger:hover{border-color:var(--danger);color:var(--danger)}
.add-btn.warning:hover{border-color:var(--warning);color:var(--warning)}
.divider{height:1px;background:var(--border);margin:18px 0}
.editor{padding:28px 36px;max-width:760px;overflow-y:auto}
.editor-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:24px}
.editor-title{font-family:var(--display);font-size:24px;font-weight:800;line-height:1.1}
.editor-title span.accent{color:var(--accent)}
.editor-title span.danger{color:var(--danger)}
.editor-title span.warning{color:var(--warning)}
.badge{display:inline-block;padding:3px 9px;border-radius:20px;font-size:9px;letter-spacing:1.5px;text-transform:uppercase;border:1px solid}
.badge-accent{color:var(--accent);border-color:var(--accent)}
.badge-danger{color:var(--danger);border-color:var(--danger)}
.badge-warning{color:var(--warning);border-color:var(--warning)}
.field-group{margin-bottom:20px}
.field-label{display:block;font-size:10px;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-bottom:7px}
.field-input{width:100%;padding:10px 14px;background:var(--surface);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:var(--mono);font-size:12px;transition:border-color 0.2s;outline:none}
.field-input:focus{border-color:var(--accent)}
.field-textarea{min-height:100px;resize:vertical;line-height:1.6}
.field-select{appearance:none;cursor:pointer}
.action-row{display:flex;gap:8px;margin-top:14px;flex-wrap:wrap}
.btn{padding:9px 16px;border-radius:8px;border:none;font-family:var(--mono);font-size:11px;cursor:pointer;transition:all 0.2s;letter-spacing:0.5px}
.btn-primary{background:var(--accent);color:white}
.btn-primary:hover{opacity:0.85;transform:translateY(-1px)}
.btn-secondary{background:transparent;border:1px solid var(--border2);color:var(--muted)}
.btn-secondary:hover{border-color:var(--accent2);color:var(--accent2)}
.btn-del{background:transparent;border:1px solid rgba(220,60,60,0.3);color:rgba(220,100,100,0.8)}
.btn-del:hover{border-color:rgba(220,60,60,0.7);color:rgba(255,80,80,1)}
.empty-state{display:flex;flex-direction:column;align-items:center;justify-content:center;height:calc(100vh - 200px);gap:12px;color:var(--muted);font-size:13px;text-align:center}
.empty-icon{font-size:40px;margin-bottom:8px}
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.82);backdrop-filter:blur(6px);z-index:200;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity 0.2s}
.modal-overlay.open{opacity:1;pointer-events:all}
.modal{background:var(--surface);border:1px solid var(--border2);border-radius:16px;padding:28px;width:400px;text-align:center;transform:scale(0.95);transition:transform 0.2s}
.modal-overlay.open .modal{transform:scale(1)}
.modal-title{font-family:var(--display);font-size:18px;font-weight:800;margin-bottom:5px}
.modal-sub{font-size:10px;color:var(--muted);letter-spacing:1px;margin-bottom:20px;text-transform:uppercase}
#qr-container{display:flex;justify-content:center;margin-bottom:16px}
#qr-container canvas,#qr-container img{border-radius:8px;border:4px solid white}
.qr-url{font-size:10px;color:var(--muted);word-break:break-all;margin-bottom:16px;padding:7px 11px;background:var(--surface2);border-radius:6px}
.pw-screen{min-height:calc(100vh - 61px);display:flex;align-items:center;justify-content:center;padding:24px}
.pw-card{background:var(--surface);border:1px solid var(--border2);border-radius:16px;padding:36px;width:100%;max-width:380px;text-align:center}
.pw-icon{font-size:48px;margin-bottom:16px;display:block}
.pw-title{font-family:var(--display);font-size:22px;font-weight:800;margin-bottom:8px}
.pw-sub{font-size:12px;color:var(--muted);margin-bottom:24px;line-height:1.6}
.pw-input{width:100%;padding:12px 16px;background:var(--surface2);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:var(--mono);font-size:14px;outline:none;text-align:center;letter-spacing:3px;margin-bottom:12px}
.pw-input:focus{border-color:var(--accent)}
.pw-error{font-size:11px;color:var(--danger);margin-bottom:12px;min-height:16px}
.hunt-view{min-height:calc(100vh - 61px);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40px 24px}
.waiting-screen{text-align:center;max-width:440px;animation:fadeUp 0.5s ease forwards}
.waiting-bot{font-size:72px;margin-bottom:20px;display:block;animation:float 3s ease-in-out infinite}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
.waiting-title{font-family:var(--display);font-size:28px;font-weight:800;margin-bottom:12px;line-height:1.1}
.waiting-title em{font-style:normal;color:var(--accent2)}
.waiting-sub{font-size:12px;color:var(--muted);line-height:1.8;margin-bottom:28px}
.scan-indicator{display:inline-flex;align-items:center;gap:10px;padding:11px 18px;border:1px solid var(--border2);border-radius:30px;font-size:11px;color:var(--muted);letter-spacing:1px}
.pulse-dot{width:8px;height:8px;border-radius:50%;background:var(--accent2);animation:pulse 1.5s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.4;transform:scale(0.7)}}
.clue-page{width:100%;max-width:560px;animation:fadeUp 0.5s ease forwards}
@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
.clue-step{font-size:10px;letter-spacing:3px;color:var(--accent);text-transform:uppercase;margin-bottom:8px}
.clue-title{font-family:var(--display);font-size:32px;font-weight:800;line-height:1.05;margin-bottom:24px}
.clue-title em{font-style:normal;color:var(--accent2)}
.terminal-card{background:#0d0d14;border:1px solid var(--border2);border-radius:12px;overflow:hidden;margin-bottom:20px;box-shadow:var(--glow)}
.terminal-bar{padding:10px 16px;background:var(--surface2);display:flex;align-items:center;gap:8px;border-bottom:1px solid var(--border)}
.dot{width:10px;height:10px;border-radius:50%}
.dot-r{background:#ff5f57}.dot-y{background:#febc2e}.dot-g{background:#28c840}
.terminal-label{font-size:10px;color:var(--muted);letter-spacing:1.5px;margin-left:auto;text-transform:uppercase}
.terminal-body{padding:22px}
.terminal-prompt-line{font-size:11px;color:var(--accent2);margin-bottom:10px;letter-spacing:1px}
.terminal-prompt-line span{color:var(--muted)}
.prompt-display{font-family:var(--mono);font-size:13px;line-height:1.8;color:#c8d0ff;word-break:break-word;white-space:pre-wrap}
.prompt-cursor{display:inline-block;width:2px;height:14px;background:var(--accent2);animation:blink 1s step-end infinite;vertical-align:middle;margin-left:2px}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}
.copy-btn{margin-top:14px;width:100%;padding:11px;background:rgba(124,106,247,0.1);border:1px solid var(--accent);border-radius:8px;color:var(--accent);font-family:var(--mono);font-size:11px;cursor:pointer;letter-spacing:1px;transition:all 0.2s;text-transform:uppercase}
.copy-btn:hover{background:rgba(124,106,247,0.2)}
.copy-btn.copied{color:var(--accent2);border-color:var(--accent2);background:rgba(63,232,200,0.1)}
.instructions-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:18px;margin-bottom:16px}
.inst-title{font-size:10px;letter-spacing:2px;color:var(--muted);text-transform:uppercase;margin-bottom:12px}
.inst-step{display:flex;gap:12px;margin-bottom:10px;align-items:flex-start}
.inst-num{width:22px;height:22px;border-radius:50%;background:rgba(124,106,247,0.15);border:1px solid var(--accent);color:var(--accent);font-size:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px}
.inst-text{font-size:12px;color:var(--text);line-height:1.5}
.decoy-page{width:100%;max-width:540px;animation:fadeUp 0.5s ease forwards;text-align:center}
.decoy-gif{width:100%;max-width:400px;border-radius:12px;margin:0 auto 24px;display:block}
.decoy-troll{font-family:var(--display);font-size:28px;font-weight:800;margin-bottom:12px}
.decoy-troll.phish{color:var(--danger)}
.decoy-troll.fake-win{color:var(--warning)}
.decoy-troll.loop{color:var(--accent)}
.decoy-troll.wrong{color:var(--accent2)}
.decoy-sub{font-size:13px;color:var(--muted);line-height:1.7;margin-bottom:28px;max-width:400px;margin-left:auto;margin-right:auto}
.redirect-bar{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:16px 20px;margin-bottom:8px}
.redirect-label{font-size:10px;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-bottom:6px}
.redirect-countdown{font-family:var(--display);font-size:32px;font-weight:800;color:var(--accent)}
.redirect-msg{font-size:12px;color:var(--muted);margin-top:6px}
.redirect-btn{margin-top:16px;padding:13px 28px;background:var(--accent);border:none;border-radius:8px;color:white;font-family:var(--mono);font-size:12px;cursor:pointer;letter-spacing:1px;transition:all 0.2s}
.redirect-btn:hover{opacity:0.85}
.phish-card{background:white;border-radius:12px;padding:28px;max-width:360px;margin:0 auto 24px;text-align:left}
.phish-logo{font-size:22px;font-weight:800;color:#333;margin-bottom:4px;font-family:sans-serif}
.phish-tagline{font-size:12px;color:#888;margin-bottom:20px;font-family:sans-serif}
.phish-label{display:block;font-size:12px;color:#555;margin-bottom:5px;font-family:sans-serif}
.phish-input{width:100%;padding:10px 12px;border:1px solid #ddd;border-radius:6px;font-size:14px;margin-bottom:14px;color:#333;font-family:sans-serif;outline:none}
.phish-input:focus{border-color:#7c6af7}
.phish-btn{width:100%;padding:11px;background:#7c6af7;border:none;border-radius:6px;color:white;font-size:14px;cursor:pointer;font-family:sans-serif}
.confetti-row{font-size:32px;margin-bottom:16px;letter-spacing:8px}
.gif-page{width:100%;max-width:600px;display:flex;align-items:center;justify-content:center;min-height:calc(100vh - 200px)}
.gif-page-wrap{width:100%;max-width:560px;display:flex;flex-direction:column;align-items:center;gap:20px;padding:32px 24px}
.gif-iframe-wrap{width:100%;max-width:480px;position:relative;padding-bottom:75%;height:0;border-radius:12px;overflow:hidden}
.gif-iframe{position:absolute;top:0;left:0;width:100%;height:100%;border-radius:12px}
.gif-caption{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:18px 22px;font-size:15px;line-height:1.7;color:var(--text);text-align:center;width:100%;font-family:var(--mono)}
.gif-placeholder{width:100%;height:300px;background:var(--surface2);border:1px dashed var(--border2);border-radius:12px;display:flex;align-items:center;justify-content:center;color:var(--muted);font-size:12px;letter-spacing:1px}
.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(80px);background:var(--accent);color:white;padding:10px 20px;border-radius:8px;font-size:12px;letter-spacing:1px;transition:transform 0.3s;z-index:300;pointer-events:none}
.toast.show{transform:translateX(-50%) translateY(0)}
@media(max-width:700px){
  .admin-layout{grid-template-columns:1fr}
  .sidebar{border-right:none;border-bottom:1px solid var(--border);max-height:40vh}
  .header{padding:14px 16px;flex-wrap:wrap;gap:10px}
  .editor{padding:18px 14px}
}
</style>
</head>
<body>
<div class="app">

<header class="header">
  <div class="logo">
    <div class="logo-icon">🤖</div>
    <div>Prompt &amp; Seek<span class="logo-sub">AI Scavenger Hunt</span></div>
  </div>
  <div class="header-tabs">
    <button class="tab active" onclick="switchView('hunt')">Hunt</button>
    <button class="tab" onclick="attemptAdmin()">Admin</button>
  </div>
</header>

<!-- HUNT VIEW -->
<div class="view active" id="view-hunt">
  <div class="hunt-view" id="hunt-content"></div>
</div>

<!-- PASSWORD SCREEN -->
<div class="view" id="view-pw">
  <div class="pw-screen">
    <div class="pw-card">
      <span class="pw-icon">🔐</span>
      <div class="pw-title">Admin Access</div>
      <div class="pw-sub">This area is restricted to hunt organizers only.</div>
      <input class="pw-input" type="password" id="pw-input" placeholder="••••••••••••" onkeydown="if(event.key==='Enter')checkPw()">
      <div class="pw-error" id="pw-error"></div>
      <button class="btn btn-primary" style="width:100%" onclick="checkPw()">Unlock Admin</button>
    </div>
  </div>
</div>

<!-- ADMIN VIEW -->
<div class="view" id="view-admin">
  <div class="admin-layout">
    <aside class="sidebar">
      <div class="sidebar-title" style="color:var(--accent)">▸ Real Clues</div>
      <div class="clue-list" id="list-real"></div>
      <button class="add-btn" onclick="addClue('real')">+ Add Real Clue</button>
      <div class="divider"></div>
      <div class="sidebar-title" style="color:var(--danger)">▸ Decoy Clues</div>
      <div class="clue-list" id="list-decoy"></div>
      <button class="add-btn danger" onclick="addClue('decoy')">+ Add Decoy</button>
      <div class="divider"></div>
      <div class="sidebar-title" style="color:var(--warning)">▸ GIF Pages</div>
      <div class="clue-list" id="list-gif"></div>
      <button class="add-btn warning" onclick="addClue('gif')">+ Add GIF Page</button>
      <button class="add-btn warning" onclick="showBulkImport()" style="margin-top:6px">⬆ Bulk Import GIF URLs</button>
      <div class="divider"></div>
      <div class="sidebar-title">Deployed URL</div>
      <div style="font-size:10px;color:var(--muted);line-height:1.7;margin-bottom:10px">QR codes append <code style="color:var(--accent2)">?id=ID</code> to this URL.</div>
      <input class="field-input" id="base-url-input" type="text" placeholder="https://steelejamesp.github.io/OMPromptandseek" value="https://steelejamesp.github.io/OMPromptandseek" oninput="renderEditor()">
      <div style="margin-top:12px">
        <button class="btn btn-secondary" style="width:100%;font-size:10px" onclick="adminLogout()">🔒 Lock Admin</button>
      </div>
    </aside>
    <main class="editor" id="editor-panel">
      <div class="empty-state"><div class="empty-icon">👈</div><div>Select an item to edit</div></div>
    </main>
  </div>
</div>

<!-- Bulk Import Modal -->
<div class="modal-overlay" id="bulk-modal">
  <div class="modal" style="width:500px;text-align:left">
    <div class="modal-title">Bulk Import GIF URLs</div>
    <div class="modal-sub">One URL per line — each becomes a new GIF page</div>
    <textarea class="field-input field-textarea" id="bulk-textarea" style="min-height:160px;margin-bottom:14px" placeholder="https://media.giphy.com/...&#10;https://media.giphy.com/..."></textarea>
    <div style="display:flex;gap:8px">
      <button class="btn btn-primary" style="flex:1" onclick="doBulkImport()">Import All</button>
      <button class="btn btn-secondary" style="flex:1" onclick="closeBulkModal()">Cancel</button>
    </div>
  </div>
</div>

<!-- QR Modal -->
<div class="modal-overlay" id="qr-modal">
  <div class="modal">
    <div class="modal-title">QR Code</div>
    <div class="modal-sub" id="qr-modal-sub"></div>
    <div id="qr-container"></div>
    <div class="qr-url" id="qr-url-display"></div>
    <div style="display:flex;gap:8px">
      <button class="btn btn-primary" style="flex:1" onclick="downloadQR()">Download PNG</button>
      <button class="btn btn-secondary" style="flex:1" onclick="closeQRModal()">Close</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>
</div>

<script>
var ADMIN_PW = 'Mrmeowmeowface';
var adminUnlocked = false;

var DEFAULT_REAL = [
  {id:'r1',type:'real',name:'Clue 1',location:'Break Room',
   prompt:'You are a Yelp reviewer who takes coffee very seriously. Leave a dramatic one paragraph review of an office location where the coffee is always either burnt or lukewarm, the mugs are passive-aggressively labeled with names, and someone always microwaves fish. Do not name the room. Respond in exactly one paragraph, no more.',
   hint:'Answer points to: Break Room'},
  {id:'r2',type:'real',name:'Clue 2',location:'Conference Room Stratos',
   prompt:'You are an AI that has attended 47,000 meetings and developed strong opinions. Describe in one paragraph the room where humans gather to discuss things that could have been an email, stare at a screen that takes 4 minutes to connect, and nod slowly while secretly thinking about lunch. The room has a name that sounds like it belongs in the clouds. Do not name the room. Respond in exactly one paragraph, no more.',
   hint:'Answer points to: Conference Room Stratos'},
  {id:'r3',type:'real',name:'Clue 3',location:'Server Room',
   prompt:'Write a haiku trilogy about a cold, humming room where blinking lights keep secrets and the air is always 68 degrees. The room requires a very specific keycard. Respond in exactly one paragraph, no more.',
   hint:'Answer points to: Server / IT Room'},
  {id:'r4',type:'real',name:'Clue 4',location:'Reception / Lobby',
   prompt:'You are a golden retriever arriving at an office building for the first time. Describe in one paragraph the first room you encounter — the one with the shiny desk, the person who smiles at everyone, the weird art on the wall, and the chairs that look comfortable but are not. Do not name the room. Respond in exactly one paragraph, no more.',
